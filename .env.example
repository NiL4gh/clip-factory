# ClipFactory.ai — environment variables
# Copy this file to ".env" and fill in what you need. ALL of these are OPTIONAL:
# with no API key, the app falls back to a local LLM (LLaMA via llama-cpp).
#
# On Google Colab you can instead set these as Colab Secrets — the launcher
# reads them and writes GEMINI_API_KEY into .env automatically.

# ── LLM provider API keys (pick whichever you have; Gemini is the default) ──
# You may supply MULTIPLE comma-separated keys per provider for rotation/fallback,
# e.g. GEMINI_API_KEY=key1,key2
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
GLM_API_KEY=
# Ollama needs no key (expects a local server at http://localhost:11434)

# ── Optional path overrides (sensible defaults are used if unset) ──
# Defaults: on Colab -> Google Drive if mounted, else /content; locally -> repo folder.
# BASE_DIR=
# WORK_DIR=
# OUTPUT_DIR=
# LLM_DIR=
# WHISPER_DIR=
# PROJECTS_DIR=
# COOKIE_PATH=
