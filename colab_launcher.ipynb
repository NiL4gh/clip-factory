   "source": [
    "# 🧠 ClipFactory AI Director — Phase 4: SaaS Dashboard\n",
    "> The ultimate AI-powered video repurposing engine. Premium Next.js dashboard with AI persona detection, fluff removal, story stitching, and a Netflix-style render gallery.\n",
    "\n",
    "**Runtime:** Make sure you're on **T4 GPU** (Runtime > Change runtime type > T4 GPU) for LLaMA 3 acceleration.\n",
    "\n",
    "### What's New in Phase 4\n",
    "- **SaaS Dashboard:** Full Next.js frontend with premium glassmorphism UI\n",
    "- **Gallery View:** Netflix-style rendered clip library with hover-to-play previews\n",
    "- **Transcript Editor:** Word-level fluff removal with visual strikethrough\n",
    "- **Stitch Visualization:** Mini timeline bars for multi-segment clips\n",
    "- **Dual Server:** FastAPI backend + Next.js frontend via ngrok\n",
    "\n",
    "### Steps\n",
    "1. Run **Cell 0** to mount Google Drive (models persist across sessions)\n",
    "2. Run **Cell 1** once per session (installs everything, ~4 min)\n",
    "3. Run **Cell 2** to launch — open the public URL it prints\n"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "drive_mount"
   },
   "source": [
    "# ── OPTIONAL: Mount Google Drive Without the Python Auth Wall ────────────────\n",
    "# To avoid the massive verification popup, DO NOT use python to mount.\n",
    "# Instead, click the 📁 Folder icon on the far left sidebar of Colab,\n",
    "# then click the 'Mount Drive' icon (a folder with the Google Drive logo).\n",
    "# This uses your browser's active session securely without a python popup.\n",
    "import os\n",
    "if os.path.exists('/content/drive/MyDrive'):\n",
    "    print('✅ Drive successfully detected.')\n",
    "else:\n",
    "    print('⚠️ Drive not mounted. Your files will be saved to temporary Colab storage.')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "setup_cell"
   },
   "source": [
    "# ── CELL 1: Setup (run once per session, ~4 min) ────────────────────────────────\n",
    "import os, subprocess, sys\n",
    "\n",
    "REPO_DIR = '/content/clip-factory'\n",
    "\n",
    "# Clone or update the repo\n",
    "if not os.path.exists(REPO_DIR):\n",
    "    subprocess.run(['git', 'clone', '--depth', '1',\n",
    "                    'https://github.com/NiL4gh/clip-factory',\n",
    "                    REPO_DIR], check=True)\n",
    "else:\n",
    "    subprocess.run(['git', '-C', REPO_DIR, 'pull'], check=True)\n",
    "    print('Repo up to date.')\n",
    "\n",
    "# Install Python dependencies\n",
    "!pip install -q -r {REPO_DIR}/requirements.txt\n",
    "!pip install -q pyngrok\n",
    "\n",
    "# Install llama-cpp-python from prebuilt CUDA wheel (skips 10-min compile)\n",
    "!pip install llama-cpp-python --prefer-binary --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cu124\n",
    "\n",
    "# Install Deno for yt-dlp JS challenge solver (fixes YouTube bot-check)\n",
    "!curl -fsSL https://deno.land/install.sh | sh\n",
    "os.environ['PATH'] = os.path.expanduser('~/.deno/bin') + ':' + os.environ['PATH']\n",
    "\n",
    "# Install fonts for captions\n",
    "!apt-get install -q -y fonts-liberation 2>/dev/null || true\n",
    "\n",
    "# Build Next.js static export\n",
    "print('\\n── Building Next.js dashboard (static export)...')\n",
    "!curl -fsSL https://deb.nodesource.com/setup_20.x | bash -q && apt-get install -y -q nodejs 2>/dev/null\n",
    "!cd {REPO_DIR}/frontend && npm install --legacy-peer-deps 2>/dev/null && npm run build 2>&1 | tail -5\n",
    "\n",
    "sys.path.insert(0, REPO_DIR)\n",
    "print('✅ Ready to launch.')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "launch_cell"
   },
   "source": [
    "# ── CELL 2: Launch ClipFactory.ai SaaS Dashboard ──────────────────────────────\n",
    "import os, sys, subprocess, threading, time\n",
    "\n",
    "# Check for GPU\n",
    "try:\n",
    "    subprocess.check_output('nvidia-smi')\n",
    "    print('✅ GPU Detected. LLaMA 3 will run with acceleration.')\n",
    "except:\n",
    "    print('❌ WARNING: No GPU detected! The AI Director will be extremely slow on CPU.')\n",
    "\n",
    "REPO_DIR = '/content/clip-factory'\n",
    "os.chdir(REPO_DIR)\n",
    "if REPO_DIR not in sys.path:\n",
    "    sys.path.insert(0, REPO_DIR)\n",
    "\n",
    "# Auto-detect Drive for persistence\n",
    "if os.path.exists('/content/drive/MyDrive'):\n",
    "    BASE = '/content/drive/MyDrive/clip_factory'\n",
    "    print('✅ Saving models and projects to Google Drive.')\n",
    "else:\n",
    "    BASE = '/content/clip_factory'\n",
    "    print('⚠️ Using local ephemeral storage.')\n",
    "\n",
    "os.environ['LLM_DIR']      = f'{BASE}/models/llm'\n",
    "os.environ['WHISPER_DIR']  = f'{BASE}/models/whisper'\n",
    "os.environ['OUTPUT_DIR']   = f'{BASE}/output'\n",
    "os.environ['PROJECTS_DIR'] = f'{BASE}/projects'\n",
    "\n",
    "for d in [os.environ['LLM_DIR'], os.environ['WHISPER_DIR'],\n",
    "          os.environ['OUTPUT_DIR'], os.environ['PROJECTS_DIR']]:\n",
    "    os.makedirs(d, exist_ok=True)\n",
    "\n",
    "# ── Start FastAPI backend ──────────────────────────────────────────────────\n",
    "def run_backend():\n",
    "    import uvicorn\n",
    "    uvicorn.run('server.main:app', host='0.0.0.0', port=8000, log_level='warning')\n",
    "\n",
    "backend_thread = threading.Thread(target=run_backend, daemon=True)\n",
    "backend_thread.start()\n",
    "time.sleep(2)\n",
    "print('✅ FastAPI backend running on port 8000')\n",
    "\n",
    "# ── Start Next.js static server (or dev) ──────────────────────────────────\n",
    "# Serve the pre-built Next.js output via a simple HTTP server\n",
    "frontend_dir = os.path.join(REPO_DIR, 'frontend')\n",
    "out_dir = os.path.join(frontend_dir, 'out')  # Next.js static export\n",
    "if os.path.isdir(out_dir):\n",
    "    # Use python http.server for the static build\n",
    "    def run_frontend():\n",
    "        import http.server, socketserver\n",
    "        os.chdir(out_dir)\n",
    "        handler = http.server.SimpleHTTPRequestHandler\n",
    "        with socketserver.TCPServer(('0.0.0.0', 3000), handler) as httpd:\n",
    "            httpd.serve_forever()\n",
    "    frontend_thread = threading.Thread(target=run_frontend, daemon=True)\n",
    "    frontend_thread.start()\n",
    "else:\n",
    "    # Fallback: run Next.js dev server\n",
    "    subprocess.Popen(['npx', 'next', 'dev', '-p', '3000'], cwd=frontend_dir,\n",
    "                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)\n",
    "time.sleep(2)\n",
    "print('✅ Frontend running on port 3000')\n",
    "\n",
    "# ── Create ngrok tunnels ──────────────────────────────────────────────────\n",
    "from pyngrok import ngrok\n",
    "\n",
    "# Authenticate with your hardcoded token\n",
    "ngrok.set_auth_token('3DHR9cBJA1DwgIYWqm28CFKjkQT_3E1sWDqq5LvfsSYdQzkUm')\n",
    "\n",
    "api_tunnel = ngrok.connect(8000, 'http')\n",
    "ui_tunnel  = ngrok.connect(3000, 'http')\n",
    "\n",
    "api_url = api_tunnel.public_url\n",
    "ui_url  = ui_tunnel.public_url\n",
    "\n",
    "print(f'\\n{\"═\" * 60}')\n",
    "print(f'  🚀  ClipFactory.ai is LIVE')\n",
    "print(f'  Dashboard:  {ui_url}')\n",
    "print(f'  API:        {api_url}')\n",
    "print(f'{\"═\" * 60}')\n",
    "print(f'\\n⚠️  Set API_BASE in the browser console:')\n",
    "print(f'    window.__NEXT_PUBLIC_API_URL = \\\"{api_url}/api\\\"')\n",
    "print(f'\\n   Then refresh the page. This points the UI to the Colab backend.')\n",
    "\n",
    "# Keep the cell alive\n",
    "try:\n",
    "    while True:\n",
    "        time.sleep(60)\n",
    "except KeyboardInterrupt:\n",
    "    ngrok.kill()\n",
    "    print('Tunnels closed.')\n"
   ],
